<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hermes Cockpit v8 — Sentinel</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

  :root {
    --bg-deep: #070a14;
    --bg-surface: #0e1222;
    --bg-glass: rgba(14, 18, 34, 0.7);
    --bg-glass-hover: rgba(20, 25, 44, 0.8);
    --bg-card: rgba(16, 20, 36, 0.65);
    --bg-card-hover: rgba(20, 25, 44, 0.75);
    --border-glass: rgba(255, 255, 255, 0.06);
    --border-glass-hover: rgba(255, 255, 255, 0.12);
    --accent-blue: #5b9cf5;
    --accent-blue-glow: rgba(91, 156, 245, 0.2);
    --accent-orange: #f0a050;
    --accent-yellow: #e0c44c;
    --accent-purple: #9b6cf0;
    --text-primary: #e1e5f2;
    --text-secondary: #8b90a6;
    --text-dim: #545a6e;
    --success: #40c463;
    --warning: #f0a050;
    --danger: #e05555;
    --radius-xl: 20px;
    --radius-lg: 14px;
    --radius-md: 10px;
    --radius-sm: 7px;
    --shadow-glass: 0 8px 32px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.04) inset;
    --shadow-glass-hover: 0 12px 44px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.07) inset;
    --shadow-card: 0 4px 20px rgba(0,0,0,0.35);
    --font-ui: 'Inter', -apple-system, 'Helvetica Neue', sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font-ui);
    background: var(--bg-deep);
    color: var(--text-primary);
    min-height: 100vh;
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse at 15% 20%, rgba(91,156,245,0.04) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 50%, rgba(240,160,80,0.03) 0%, transparent 55%),
      radial-gradient(ellipse at 40% 85%, rgba(224,196,76,0.02) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
  }

  /* === LAYOUT === */
  .app-shell { display: flex; height: 100vh; position: relative; z-index: 1; }

  /* === SIDEBAR === */
  :root { --sidebar-width: 280px; }

  .sidebar {
    width: var(--sidebar-width); flex-shrink: 0;
    background: linear-gradient(180deg, #0d1117 0%, #131922 100%);
    border-right: 1px solid rgba(127,179,255,0.12);
    display: flex; flex-direction: column;
    padding: 14px 10px; gap: 2px;
    overflow-y: auto;
    position: relative;
  }

  .sidebar-resize-handle {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: 5px; cursor: col-resize; z-index: 10;
  }
  .sidebar-resize-handle:hover { background: rgba(91,156,245,0.15); }

  .sidebar-header {
    display: flex; align-items: center; gap: 8px;
    padding: 2px 6px 10px;
    border-bottom: 1px solid var(--border-glass);
    margin-bottom: 4px;
  }

  .sidebar-logo {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, var(--accent-blue), #3b74c0);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    box-shadow: 0 4px 14px var(--accent-blue-glow);
  }

  .sidebar-title { font-weight: 700; font-size: 14px; color: var(--text-primary); }
  .sidebar-subtitle { font-size: 9px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }

  .widget-library-label {
    font-size: 9px; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--text-dim); font-weight: 700; padding: 12px 6px 6px;
    display: flex; justify-content: space-between; align-items: center;
  }

  .widget-library-label .hint { font-weight: 400; font-size: 7px; color: var(--text-secondary); opacity: 0.6; }

  .lib-widget {
    display: flex; align-items: center; gap: 10px;
    padding: 13px 8px; border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid transparent;
    cursor: grab; transition: var(--transition);
    font-size: 15px; color: #b3beca;
    user-select: none; position: relative;
  }

  .lib-widget:hover {
    background: rgba(127,179,255,0.08);
    border-color: transparent;
    color: #d4dbe8;
  }

  .lib-widget span { color: inherit; }
  .lib-widget:active { cursor: grabbing; }
  .lib-widget.dragging { opacity: 0.4; border: 1px dashed var(--accent-blue); }

  .lib-widget.placed {
    background: rgba(127,179,255,0.10);
    border: 1px solid rgba(127,179,255,0.15);
    border-left: 3px solid #7fb3ff;
    color: #ffffff;
    cursor: default; opacity: 1; pointer-events: auto;
  }

  .lib-widget.placed::after {
    content: '✓'; position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
    font-size: 11px; color: #7fb3ff; font-weight: 700;
    background: rgba(127,179,255,0.18);
    border-radius: 50%; width: 20px; height: 20px;
    display: flex; align-items: center; justify-content: center;
    line-height: 1;
  }

  /* Locked state — sidebar dims */
  .app-shell.locked .lib-widget:not(.placed) {
    opacity: 0.35; cursor: not-allowed; pointer-events: none;
  }

  .lib-icon {
    width: 26px; height: 26px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; flex-shrink: 0;
    color: #5a6675; background: rgba(127,179,255,0.06);
    transition: var(--transition);
  }

  .lib-icon.tasks { background: rgba(91,156,245,0.08); color: var(--accent-blue); }
  .lib-icon.agents { background: rgba(155,108,240,0.08); color: var(--accent-purple); }
  .lib-icon.system { background: rgba(240,160,80,0.08); color: var(--accent-orange); }
  .lib-icon.jobs { background: rgba(224,196,76,0.08); color: var(--accent-yellow); }
  .lib-icon.terminal { background: rgba(127,179,255,0.08); color: #7fb3ff; }
  .lib-icon.news { background: rgba(240,160,80,0.08); color: var(--accent-orange); }
  .lib-icon.weather { background: rgba(127,179,255,0.08); color: #7fb3ff; }
  .lib-icon.skills { background: rgba(155,108,240,0.08); color: var(--accent-purple); }

  .lib-widget.placed .lib-icon {
    color: #7fb3ff; background: rgba(127,179,255,0.12);
  }

  .sidebar-footer { margin-top: auto; padding-top: 10px; border-top: 1px solid rgba(127,179,255,0.12); }
  .sidebar-footer .stat-row { display: flex; justify-content: space-between; padding: 3px 0; font-size: 12px; }
  .sidebar-footer .stat-row .lbl { color: var(--text-secondary); }
  .sidebar-footer .stat-row .val { font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); }
  .mini-bar { height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; margin: 4px 0 8px; overflow: hidden; }
  .mini-bar-fill { height: 100%; border-radius: 2px; transition: width 1s; }
  .mini-bar-fill.blue { background: var(--accent-blue); }
  .mini-bar-fill.orange { background: var(--accent-orange); }

  /* === DASHBOARD === */
  .dashboard {
    flex: 1; display: flex; flex-wrap: wrap; align-content: flex-start;
    padding: 10px; gap: 8px; overflow-y: auto; position: relative; min-height: 0;
  }

  .dashboard.drag-over {
    background: rgba(91,156,245,0.02);
    outline: 2px dashed rgba(91,156,245,0.15); outline-offset: -6px;
  }

  /* === v8: DROP PREVIEW (Auto-Umordnen — Auto-Umordnen mit Vorschau) === */
  .drop-preview {
    border: 2px dashed #7fb3ff !important;
    background: rgba(127,179,255,0.08) !important;
    border-radius: var(--radius-md);
    min-width: 180px; min-height: 100px;
    flex-shrink: 0;
    animation: previewGlow 1.2s ease-in-out infinite;
    pointer-events: none;
    box-shadow:
      0 0 20px rgba(127,179,255,0.15),
      inset 0 0 20px rgba(127,179,255,0.04),
      0 0 40px rgba(127,179,255,0.06);
  }

  @keyframes previewGlow {
    0%, 100% { 
      border-color: rgba(127,179,255,0.3); 
      box-shadow: 0 0 16px rgba(127,179,255,0.08), inset 0 0 14px rgba(127,179,255,0.02), 0 0 30px rgba(127,179,255,0.04); 
    }
    50% { 
      border-color: rgba(127,179,255,0.7); 
      box-shadow: 0 0 28px rgba(127,179,255,0.2), inset 0 0 24px rgba(127,179,255,0.06), 0 0 55px rgba(127,179,255,0.1); 
    }
  }

  .widget.reorder-shift {
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), margin 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dashboard.reordering .widget {
    transition: transform 0.2s ease-out, margin 0.2s ease-out;
  }

  /* === v8: SIZE PICKER OVERLAY (Auto-Size) === */
  .size-picker {
    position: fixed;
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-md);
    padding: 6px;
    display: flex; gap: 4px;
    z-index: 100;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    animation: fadeSlideUp 0.2s ease-out;
    pointer-events: auto;
  }

  .size-btn {
    padding: 6px 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 10px;
    transition: var(--transition);
    white-space: nowrap;
  }

  .size-btn:hover {
    background: rgba(91,156,245,0.12);
    border-color: rgba(91,156,245,0.3);
    color: var(--text-primary);
  }

  .size-btn.active {
    background: rgba(91,156,245,0.15);
    border-color: var(--accent-blue);
    color: var(--accent-blue);
  }

  /* === v8: LOCK BUTTON === */
  .lock-toggle {
    position: fixed;
    top: 12px; right: 16px; z-index: 50;
    width: 36px; height: 36px;
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    transition: var(--transition);
    color: var(--text-dim);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .lock-toggle:hover { border-color: var(--border-glass-hover); color: var(--text-primary); }
  .lock-toggle.locked { color: var(--accent-orange); border-color: rgba(240,160,80,0.2); background: rgba(240,160,80,0.06); }

  /* Locked dashboard state */
  .app-shell.locked .widget .widget-header { cursor: default; }
  .app-shell.locked .widget .w-remove { display: none; }
  .app-shell.locked .widget .resize-handle { display: none; }
  .app-shell.locked .widget { cursor: default; }
  .app-shell.locked .widget[draggable="true"] { pointer-events: auto; }
  .app-shell.locked .dashboard.drag-over { outline: none; background: transparent; }

  .lock-indicator {
    position: fixed; top: 18px; left: 50%; transform: translateX(-50%); z-index: 60;
    font-size: 10px; font-weight: 600; color: var(--accent-orange);
    background: rgba(240,160,80,0.08); border: 1px solid rgba(240,160,80,0.15);
    padding: 4px 14px; border-radius: 20px;
    pointer-events: none;
    animation: fadeSlideUp 0.3s ease-out;
    display: none;
  }

  .app-shell.locked .lock-indicator { display: none; }

  /* === WIDGETS === */
  .widget {
    background: var(--bg-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    transition: var(--transition);
    position: relative;
    min-width: 180px;
    min-height: 100px;
    display: flex; flex-direction: column;
  }

  .widget:hover {
    border-color: var(--border-glass-hover);
    box-shadow: var(--shadow-glass-hover);
  }

  .widget.drag-ghost { opacity: 0.3; transform: scale(0.97); }
  .widget.resizing { transition: none; user-select: none; }

  .widget-header {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    cursor: grab; user-select: none;
    flex-shrink: 0;
  }

  .widget-header:active { cursor: grabbing; }

  .widget-header .w-icon { font-size: 13px; }
  .widget-header .w-name { font-weight: 600; font-size: 10px; flex: 1; }

  /* Per-widget lock */
  .w-lock {
    width: 18px; height: 18px; border-radius: 4px;
    background: transparent; border: none; cursor: pointer;
    font-size: 11px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition); flex-shrink: 0;
    padding: 0; color: var(--text-dim);
  }
  .w-lock:hover { color: var(--text-primary); background: rgba(255,255,255,0.06); }
  .w-lock.locked { color: var(--accent-orange); }

  .widget.widget-locked {
    border: 1px dashed var(--accent-orange);
  }
  .widget.widget-locked .widget-body {
    pointer-events: none;
  }
  .widget.widget-locked .widget-header {
    cursor: default;
  }
  .widget.widget-locked .w-remove { display: none; }
  .widget.widget-locked .resize-handle { display: none; }

  .w-fs-btn {
    width: 18px; height: 18px; border-radius: 4px;
    background: rgba(255,255,255,0.04); border: none; cursor: pointer;
    color: var(--text-dim); font-size: 10px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition); flex-shrink: 0;
    font-family: var(--font-ui); line-height: 1;
  }

  .w-fs-btn:hover { background: rgba(255,255,255,0.1); color: var(--text-primary); }

  .w-remove {
    width: 20px; height: 20px; border-radius: 50%;
    background: rgba(255,255,255,0.04); border: none; cursor: pointer;
    color: var(--text-dim); font-size: 12px;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition); flex-shrink: 0;
  }

  .w-remove:hover { background: rgba(224,85,85,0.15); color: var(--danger); }

  .widget-body {
    padding: 8px 10px;
    flex: 1; overflow-y: auto;
    min-height: 0;
    font-size: 10px;
  }

  .widget[data-widget="terminal"] .widget-body {
    display: flex; flex-direction: column;
    overflow: hidden; padding: 6px 8px 4px;
  }

  /* === STEUERUNG WIDGET === */
  .steuerung-panel { display: flex; flex-direction: column; gap: 8px; }
  .steu-section { padding: 4px 0; }
  .steu-section-title { font-size: 0.85em; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; border-bottom: 1px solid var(--border-glass); padding-bottom: 2px; }
  .steu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; }
  .steu-status-row { display: flex; align-items: center; gap: 5px; font-size: 0.85em; padding: 1px 0; }
  .steu-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .steu-ok { background: var(--success); } .steu-warn { background: var(--warning); } .steu-no { background: var(--danger); }
  .steu-prio-group { margin-bottom: 5px; }
  .steu-prio-head { font-size: 0.75em; font-weight: 700; padding: 1px 6px; border-radius: 3px; margin-bottom: 2px; display: inline-block; }
  .steu-check-row { font-size: 0.82em; padding: 1px 0; cursor: pointer; display: flex; align-items: center; gap: 4px; }
  .steu-check { cursor: pointer; font-size: 1.1em; user-select: none; }
  .steu-check.steu-done { color: var(--success); }
  .steu-action-btn { display: block; width: 100%; text-align: left; padding: 4px 8px; margin: 2px 0; background: var(--bg-glass); border: 1px solid var(--border-glass); border-radius: 4px; color: var(--text-primary); font-size: 0.82em; cursor: pointer; font-family: var(--font-ui); transition: var(--transition); }
  .steu-action-btn:hover { background: var(--bg-glass-hover); border-color: var(--border-glass-hover); }
  .steu-action-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .steu-notready { font-size: 0.8em; color: var(--text-dim); }

  /* Resize handle */
  .resize-handle {
    position: absolute;
    bottom: 2px; right: 2px;
    width: 16px; height: 16px;
    cursor: nwse-resize;
    display: flex; align-items: flex-end; justify-content: flex-end;
    opacity: 0; transition: opacity 0.15s;
    z-index: 5;
  }

  .widget:hover .resize-handle { opacity: 0.5; }
  .resize-handle:hover { opacity: 1 !important; }

  .resize-handle::after {
    content: '╱';
    font-size: 11px; color: var(--text-secondary);
    line-height: 1; font-family: var(--font-mono);
  }

  /* ================================================================
     TASK ANIMATIONS (v4-Style)
     ================================================================ */
  @keyframes taskComplete {
    0%   { transform: scale(1); opacity: 1; filter: brightness(1); }
    40%  { transform: scale(1.03); filter: brightness(1.4); border-color: var(--success); background: rgba(64,196,99,0.06); }
    80%  { transform: scale(0.96); opacity: 0.7; }
    100% { transform: scale(0.98); opacity: 0.5; filter: brightness(0.8); }
  }

  @keyframes taskArrive {
    from { transform: translateY(-12px); opacity: 0; }
    to   { transform: translateY(0); opacity: 0.5; }
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .task-card {
    background: var(--bg-card);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    margin-bottom: 5px;
    cursor: pointer;
    transition: var(--transition);
    animation: fadeSlideUp 0.35s ease-out backwards;
  }

  .task-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-glass-hover);
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .task-card.pending-card { border-left: 2px solid var(--accent-blue); }
  .task-card.completed-card {
    border-left: 2px solid var(--success);
    opacity: 0.55;
  }

  .task-card.completing {
    animation: taskComplete 0.5s ease-out forwards;
    pointer-events: none;
  }

  .task-card.arriving {
    animation: taskArrive 0.4s ease-out forwards;
    pointer-events: none;
  }

  .task-card-header {
    display: flex; align-items: center; gap: 8px;
  }

  .task-check-circle {
    width: 18px; height: 18px; border-radius: 50%;
    border: 2px solid var(--text-dim); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8em; color: transparent;
    transition: var(--transition);
  }

  .task-card:hover .task-check-circle { border-color: var(--accent-blue); }

  .task-card.completed-card .task-check-circle {
    background: var(--success); border-color: var(--success);
    color: #fff;
  }

  .task-title { font-weight: 500; font-size: 1.1em; color: var(--text-secondary); flex: 1; }
  .task-card:hover .task-title { color: var(--text-primary); }
  .task-card.completed-card .task-title { text-decoration: line-through; color: var(--text-dim); }

  .task-meta {
    display: flex; gap: 8px; align-items: center;
    margin-top: 5px; font-size: 0.85em; color: var(--text-dim);
  }

  .priority { font-size: 0.7em; padding: 1px 5px; border-radius: 3px; font-weight: 600; }
  .priority.high { background: rgba(224,85,85,0.15); color: var(--danger); }
  .priority.medium { background: rgba(240,160,80,0.12); color: var(--warning); }

  .task-col { flex: 1; }
  .task-col-label {
    font-size: 0.9em; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; margin-bottom: 6px;
  }
  .task-col-label.pending { color: var(--accent-blue); }
  .task-col-label.done { color: var(--text-dim); }

  .task-add {
    font-size: 0.9em; color: var(--text-dim); cursor: pointer;
    padding: 6px 10px; margin-top: 4px;
    background: rgba(255,255,255,0.015);
    border: 1px dashed var(--border-glass);
    border-radius: var(--radius-sm);
    text-align: center; transition: var(--transition);
  }
  .task-add:hover { color: var(--text-secondary); border-color: var(--border-glass-hover); background: rgba(255,255,255,0.03); }

  .task-split { display: flex; gap: 12px; }

  /* Empty state */
  .empty-column {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 30px 20px; gap: 6px;
    color: var(--text-dim); font-size: 1em;
    flex: 1;
  }
  .empty-column .ec-icon { font-size: 2.2em; margin-bottom: 4px; opacity: 0.35; }

  /* ================================================================
     AGENTS (v3-Style Avatars)
     ================================================================ */
  .agent-card {
    display: flex; align-items: center; gap: 10px;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.02);
    transition: var(--transition);
  }
  .agent-card:last-child { border-bottom: none; }
  .agent-card:hover { color: var(--text-primary); }

  .agent-avatar {
    width: 30px; height: 30px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3em; font-weight: 700; flex-shrink: 0;
