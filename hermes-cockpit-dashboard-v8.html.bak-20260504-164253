<script>
  // ========== CONSTANTS ==========
  const SNAP = 20;
  const STORAGE_KEY = 'hermes-cockpit-v8';

  // ========== STATE ==========
  let appState = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null') || {
    order: ['steuerung', 'tasks', 'agents', 'system', 'terminal', 'jobs'],
    configs: {},
    locked: false
  };

  const DEFAULT_CONFIGS = {
    tasks:    { w: '360px', h: 'auto', fs: 10 },
    agents:   { w: '260px', h: 'auto', fs: 10 },
    system:   { w: '260px', h: 'auto', fs: 10 },
    jobs:     { w: '260px', h: 'auto', fs: 10 },
    terminal: { w: '400px', h: 'auto', fs: 10 },
    news:     { w: '300px', h: 'auto', fs: 10 },
    weather:  { w: '240px', h: 'auto', fs: 10 },
    skills:   { w: '280px', h: 'auto', fs: 10 },
    steuerung:{ w: '420px', h: 'auto', fs: 10 },
    chat:     { w: '360px', h: 'auto', fs: 10 }
  };

  // Size presets for Auto-Size
  const SIZE_PRESETS = [
    { label: '¼', w: '25%', desc: 'Viertel' },
    { label: '½', w: '50%', desc: 'Halb' },
    { label: '¾', w: '75%', desc: 'Dreiviertel' },
    { label: '≡', w: '100%', desc: 'Voll' },
    { label: '↺', w: null, desc: 'Standard' }
  ];

  // ========== WIDGET DEFINITIONS ==========
  const WIDGET_DEFS = {
    tasks: {
      name: 'Task Board', icon: '☐',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = `
          <div class="task-split" id="tasksContainer">
            <div class="task-col" id="taskColPending">
              <div class="task-col-label pending">⬜ Offen (<span class="cnt">0</span>)</div>
            </div>
            <div class="task-col" id="taskColDone">
              <div class="task-col-label done">✅ Erledigt (<span class="cnt">0</span>)</div>
            </div>
          </div>
        `;
      }
    },
    agents: {
      name: 'Agenten', icon: '◈',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = '<div id="agentsContainer"><span class="term-dim">Lade Agenten…</span></div>';
      }
    },
    system: {
      name: 'System Monitor', icon: '⊞',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = `
          <div class="sys-row"><span class="sys-label">CPU</span><span class="sys-val" style="color:var(--accent-blue);" id="sysCpuVal">…</span></div>
          <div class="sys-bar-track"><div class="sys-bar-fill cpu" id="sysCpuBar" style="width:0%;"></div></div>
          <div class="sys-row" style="margin-top:6px;"><span class="sys-label">RAM</span><span class="sys-val" style="color:var(--accent-orange);" id="sysRamVal">…</span></div>
          <div class="sys-bar-track"><div class="sys-bar-fill ram" id="sysRamBar" style="width:0%;"></div></div>
          <div class="sys-row" style="margin-top:6px;"><span class="sys-label">Disk</span><span class="sys-val" id="sysDiskVal">…</span></div>
          <div class="sys-bar-track"><div class="sys-bar-fill disk" id="sysDiskBar" style="width:0%;"></div></div>
          <div class="sys-row" style="margin-top:6px;"><span class="sys-label">Network</span><span class="sys-val" id="sysNetVal">…</span></div>
          <div class="sys-row" style="margin-top:2px;"><span class="sys-label">Online seit</span><span class="sys-val" style="font-size:0.85em;" id="sysUptimeVal">… (seit Seitenaufruf)</span></div>
        `;
      }
    },
    jobs: {
      name: 'Cron Jobs', icon: '⚙',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = '<div id="jobsContainer"><span class="term-dim">Lade Jobs…</span></div>';
      }
    },
    terminal: {
      name: 'Terminal', icon: '\u27e9_',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        if (body.querySelector('#ptyContainer')) {
          if (ptyTerm) {
            ptyTerm.options.fontSize = fs;
            if (ptyFitAddon) ptyFitAddon.fit();
          }
          return;
        }
        body.innerHTML = `
          <div class="pty-container" id="ptyContainer"></div>
          <div class="term-footer" id="termStatusFooter">
            <span class="term-status-dot term-status-dot--connecting"></span><span>verbinde...</span>
          </div>
        `;
      }
    },
    news: {
      name: 'News Feed', icon: '☀',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = '<div id="newsContainer"><span class="term-dim">Lade News…</span></div>';
      }
    },
    weather: {
      name: 'Wetter', icon: '☁',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = `
          <div class="weather-main">
            <div class="weather-icon" id="wxIcon">⏳</div>
            <div><div class="weather-temp" id="wxTemp">…</div><div class="weather-detail" id="wxDesc">Wetter wird geladen…</div></div>
          </div>
          <div class="weather-stats" id="wxStats"><span class="weather-fetching">via wttr.in…</span></div>
          <div class="weather-forecast" id="wxForecast"></div>
        `;
      }
    },
    skills: {
      name: 'Skills', icon: '✦',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = '<div id="skillsContainer"><span class="term-dim">Lade Skills…</span></div>';
      }
    },
    steuerung: {
      name: 'Steuerung', icon: '⚡',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = `
          <div class="steuerung-panel">
            <div class="steu-section"><div class="steu-section-title">Systemstatus</div><div class="steu-grid" id="steuStatus"></div></div>
            <div class="steu-section"><div class="steu-section-title">Prioritäten</div><div id="steuPrio"></div></div>
            <div class="steu-section"><div class="steu-section-title">Aktionen</div><div id="steuActions"></div></div>
          </div>
        `;
        buildSteuerung();
      }
    },
    chat: {
      name: 'Chat', icon: '💬',
      render(body, fs) {
        body.style.fontSize = fs + 'px';
        body.innerHTML = `
          <div class="chat-panel">
            <div class="chat-output" id="chatOutput_${Date.now()}" style="min-height:80px;max-height:300px;overflow-y:auto;font-family:var(--font-mono);font-size:0.9em;padding:4px;white-space:pre-wrap;color:var(--text-secondary);">Chat-Bereich — Copy &amp; Paste von/zur KI</div>
          </div>
        `;
      }
    }
  };

  // ========== STEUERUNG ENGINE ==========
  function buildSteuerung() {
    const statusData = [
      { k: 'Architektur', v: 'stabil', s: 'ok' },
      { k: 'Routing', v: 'gut', s: 'warn' },
      { k: 'Skills', v: 'mittel', s: 'warn' },
      { k: 'Automation', v: 'läuft', s: 'warn' },
      { k: 'Produktreife', v: 'im Aufbau', s: 'no' }
    ];
    const statusEl = document.getElementById('steuStatus');
    if (statusEl) statusEl.innerHTML = statusData.map(d => `
      <div class="steu-status-row"><span class="steu-dot steu-${d.s}"></span>${d.k}: ${d.v}</div>
    `).join('');

    const prioData = [
      { t: 'KRITISCH', items: ['Routing validieren','Overnight stabil','Council nutzen'], cls: 'no' },
      { t: 'WICHTIG', items: ['Skills aufräumen','Context Engineering','Memory-Qualität'], cls: 'warn' },
      { t: 'OPTIONAL', items: ['Firecrawl testen','Nous Portal prüfen'], cls: 'ok' }
    ];
    const prioEl = document.getElementById('steuPrio');
    if (prioEl) prioEl.innerHTML = prioData.map(p => `
      <div class="steu-prio-group">
        <div class="steu-prio-head steu-${p.cls}">${p.t}</div>
        ${p.items.map(i => `<div class="steu-check-row"><span class="steu-check" data-k="${i}" onclick="toggleSteuCheck(this)">☐</span>${i}</div>`).join('')}
      </div>
    `).join('');

    const actions = [
      { k: 'ollama', label: 'Ollama-Status', ready: true },
      { k: 'cronjobs', label: 'Cronjobs prüfen', ready: true },
      { k: 'skills', label: 'Skills prüfen', ready: true },
      { k: 'memory', label: 'Memory-Check', ready: true },
      { k: 'update', label: 'Update-Bericht', ready: true },
      { k: 'council', label: 'Council starten', ready: false },
      { k: 'routing', label: 'Routing-Test', ready: false }
    ];
    const actEl = document.getElementById('steuActions');
    if (actEl) actEl.innerHTML = actions.map(a => `
      <button class="steu-action-btn" data-action="${a.k}" ${a.ready ? '' : 'disabled'} onclick="handleWidgetAction('${a.k}')">
        ${a.ready ? '▶' : '⏳'} ${a.label} ${a.ready ? '' : '<span class=\"steu-notready\">(später)</span>'}
      </button>
    `).join('');

    // Restore saved checks
    const saved = JSON.parse(localStorage.getItem('steuChecks') || '{}');
    document.querySelectorAll('.steu-check').forEach(el => {
      if (saved[el.dataset.k]) { el.textContent = '☑'; el.classList.add('steu-done'); }
    });
  }

  function toggleSteuCheck(el) {
    const done = el.textContent === '☑';
    el.textContent = done ? '☐' : '☑';
    el.classList.toggle('steu-done', !done);
    const saved = JSON.parse(localStorage.getItem('steuChecks') || '{}');
    saved[el.dataset.k] = !done;
    localStorage.setItem('steuChecks', JSON.stringify(saved));
  }

  function handleWidgetAction(actionId) {
    const term = window._ptyTerm;
    const commands = {
      ollama: 'ollama list',
      cronjobs: 'hermes cron list',
      skills: 'ls ~/.hermes/skills/holger/ | head -20',
      memory: 'echo "Memory: ' + (JSON.parse(localStorage.getItem('hermes_memory') || '{}').count || '?') + ' Einträge"',
      update: 'cd ~/.hermes/hermes-agent && git log --oneline HEAD..origin/main | wc -l && echo " neue Commits verfügbar"',
      council: null,
      routing: null
    };
    const cmd = commands[actionId];
    if (!cmd) {
      if (term) term.writeln('\\x1b[33m⏳ ' + actionId + ': Backend-Hook folgt in Schicht 2\\x1b[0m');
      return;
    }
    if (term) {
      term.writeln('\\x1b[36m\\n=== ' + actionId + ' ===\\x1b[0m');
      fetch('http://localhost:9119/pty/exec', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cmd })
      }).catch(() => {
        term.writeln('\\x1b[33m⏳ Backend nicht erreichbar — Schicht 2 folgt\\x1b[0m');
      });
    }
  }

  // ========== HELPERS ==========
  function saveState() { localStorage.setItem(STORAGE_KEY, JSON.stringify(appState)); }

  function getWidgetConfig(widgetId) {
    if (!appState.configs[widgetId]) {
      appState.configs[widgetId] = { ...DEFAULT_CONFIGS[widgetId] };
    }
    return appState.configs[widgetId];
  }

  function getActiveWidgets() {
    return Array.from(document.querySelectorAll('#dashboard .widget')).map(w => w.dataset.instance || w.dataset.widget);
  }

  function esc(s) { return s.replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ========== TERM LOG ==========
  function termLog(msg) {
    if (window._ptyTerm) {
      window._ptyTerm.writeln('\x1b[32m\u2713\x1b[0m \x1b[2m' + msg + '\x1b[0m');
    } else {
      console.log('[Cockpit]', msg);
    }
  }

  // ========== FONT SIZE ==========
  function changeFont(event, widgetId, delta) {
    if (appState.locked) return;
    event.stopPropagation();
    const cfg = getWidgetConfig(widgetId);
    cfg.fs = Math.max(7, Math.min(18, cfg.fs + delta));
    appState.order = getActiveWidgets();
    saveState();
    const widget = document.querySelector(`#dashboard .widget[data-widget="${widgetId}"]`);
    if (widget) {
      const body = widget.querySelector('.widget-body');
      const def = WIDGET_DEFS[widgetId];
      if (def) def.render(body, cfg.fs);
    }
  }

  // ========== TASK ANIMATIONS ==========
  function completeTask(card) {
    if (card.classList.contains('completing')) return;
    card.classList.add('completing');
    card.onclick = null;
    setTimeout(() => {
      card.classList.remove('completing', 'pending-card');
      card.classList.add('completed-card', 'arriving');
      card.onclick = function() { uncompleteTask(this); };
      const doneCol = document.getElementById('taskColDone');
      if (doneCol) {
        const label = doneCol.querySelector('.task-col-label');
        doneCol.insertBefore(card, label ? label.nextSibling : doneCol.firstChild);
      }
      updateTaskCounts();
      termLog('Task erledigt');
      setTimeout(() => card.classList.remove('arriving'), 400);
    }, 450);
  }

  function uncompleteTask(card) {
    card.classList.remove('completed-card', 'arriving');
    card.classList.add('pending-card');
    card.onclick = function() { completeTask(this); };
    const pendingCol = document.getElementById('taskColPending');
    if (pendingCol) {
      const addLink = pendingCol.querySelector('.task-add');
      if (addLink) pendingCol.insertBefore(card, addLink);
      else pendingCol.appendChild(card);
    }
    updateTaskCounts();
    termLog('Task wieder aktiv');
  }

  function updateTaskCounts() {
    const pendingCol = document.getElementById('taskColPending');
    const doneCol = document.getElementById('taskColDone');
    if (!pendingCol || !doneCol) return;
    const pendingCards = pendingCol.querySelectorAll('.task-card.pending-card').length;
    const doneCards = doneCol.querySelectorAll('.task-card.completed-card').length;
    const pendingCnt = pendingCol.querySelector('.cnt');
    const doneCnt = doneCol.querySelector('.cnt');
    if (pendingCnt) pendingCnt.textContent = pendingCards;
    if (doneCnt) doneCnt.textContent = doneCards;
    if (pendingCards === 0 && !pendingCol.querySelector('.empty-column')) {
      const addLink = pendingCol.querySelector('.task-add');
      const empty = document.createElement('div');
      empty.className = 'empty-column';
      empty.innerHTML = '<div class="ec-icon">🎉</div><div>Alles erledigt!</div><div style="font-size:0.85em;">Neue Task mit + anlegen</div>';
      if (addLink) pendingCol.insertBefore(empty, addLink);
      else pendingCol.appendChild(empty);
    } else if (pendingCards > 0) {
      const empty = pendingCol.querySelector('.empty-column');
      if (empty) empty.remove();
    }
    if (doneCards === 0 && !doneCol.querySelector('.empty-column')) {
      const empty = document.createElement('div');
      empty.className = 'empty-column';
      empty.innerHTML = '<div class="ec-icon">📋</div><div>Noch nichts erledigt</div><div style="font-size:0.85em;">Erste Task abhaken!</div>';
      doneCol.appendChild(empty);
    } else if (doneCards > 0) {
      const empty = doneCol.querySelector('.empty-column');
      if (empty) empty.remove();
    }
  }

  function addNewTask(body) {
    const title = prompt('Neue Task:');
    if (!title) return;
    const pendingCol = document.getElementById('taskColPending');
    if (!pendingCol) return;
    const addLink = pendingCol.querySelector('.task-add');
    const empty = pendingCol.querySelector('.empty-column');
    if (empty) empty.remove();
    const card = document.createElement('div');
    card.className = 'task-card pending-card';
    card.onclick = function() { completeTask(this); };
    card.innerHTML = `
      <div class="task-card-header">
        <div class="task-check-circle">✓</div>
        <div class="task-title">${esc(title)}</div>
      </div>
      <div class="task-meta"><span class="priority medium">MEDIUM</span><span>Neu</span><span>Heute</span></div>
    `;
    if (addLink) pendingCol.insertBefore(card, addLink);
    else pendingCol.appendChild(card);
    updateTaskCounts();
    termLog('Neue Task: ' + title);
  }

  // ========== v8: LOCK / UNLOCK ==========
  function toggleLock() {
    appState.locked = !appState.locked;
    saveState();
    applyLockState();
    termLog(appState.locked ? 'Layout gesperrt 🔒' : 'Layout entsperrt 🔓');
  }

  function applyLockState() {
    const shell = document.getElementById('appShell');
    const btn = document.getElementById('lockToggle');
    if (appState.locked) {
      shell.classList.add('locked');
      btn.classList.add('locked');
      btn.textContent = '🔒';
      btn.title = 'Layout entsperren (⌘L)';
    } else {
      shell.classList.remove('locked');
      btn.classList.remove('locked');
      btn.textContent = '🔓';
      btn.title = 'Layout sperren (⌘L)';
    }
    // Update widget draggability (respect per-widget locks)
    document.querySelectorAll('#dashboard .widget').forEach(w => {
      w.draggable = !appState.locked && !w.classList.contains('widget-locked');
    });
  }

  // ========== v8: PER-WIDGET LOCK ==========
  const WIDGET_LOCK_KEY = 'widget-locks';

  function getWidgetLocks() {
    try { return JSON.parse(localStorage.getItem(WIDGET_LOCK_KEY) || '{}'); }
    catch { return {}; }
  }

  function saveWidgetLocks(locks) {
    localStorage.setItem(WIDGET_LOCK_KEY, JSON.stringify(locks));
  }

  function isWidgetLocked(widgetId) {
    return !!getWidgetLocks()[widgetId];
  }

  function toggleWidgetLock(event, widgetId) {
    event.stopPropagation();
    const locks = getWidgetLocks();
    locks[widgetId] = !locks[widgetId];
    saveWidgetLocks(locks);
    applyWidgetLockState(widgetId);
    termLog(locks[widgetId]
      ? 'Widget gesperrt 🔒: ' + (WIDGET_DEFS[widgetId]?.name || widgetId)
      : 'Widget entsperrt 🔓: ' + (WIDGET_DEFS[widgetId]?.name || widgetId));
  }

  function applyWidgetLockState(widgetId) {
    const widget = document.querySelector(`#dashboard .widget[data-widget="${widgetId}"]`);
    if (!widget) return;
    const lockBtn = widget.querySelector('.w-lock');
    const locked = isWidgetLocked(widgetId);
    if (locked) {
      widget.classList.add('widget-locked');
      widget.draggable = false;
      if (lockBtn) { lockBtn.classList.add('locked'); lockBtn.textContent = '🔒'; lockBtn.title = 'Widget entsperren'; }
    } else {
      widget.classList.remove('widget-locked');
      widget.draggable = !appState.locked;
      if (lockBtn) { lockBtn.classList.remove('locked'); lockBtn.textContent = '🔓'; lockBtn.title = 'Widget sperren'; }
    }
  }

  function applyAllWidgetLockStates() {
    const locks = getWidgetLocks();
    Object.keys(locks).forEach(widgetId => applyWidgetLockState(widgetId));
  }

  // ========== v8: AUTO-SIZE PICKER ==========
  let sizePickerTimeout = null;

  function showSizePicker(widget, widgetId) {
    removeSizePicker();
    const rect = widget.getBoundingClientRect();
    const cfg = getWidgetConfig(widgetId);
    const dashW = document.getElementById('dashboard').clientWidth - 20;

    const picker = document.createElement('div');
    picker.className = 'size-picker';
    picker.id = 'sizePicker';

    SIZE_PRESETS.forEach(preset => {
      const btn = document.createElement('button');
      btn.className = 'size-btn';
      btn.textContent = preset.label;
      btn.title = preset.desc;
      // Highlight current approximate width
      const currentW = widget.offsetWidth;
      if (preset.w) {
        const pct = parseInt(preset.w);
        const targetW = dashW * pct / 100;
        if (Math.abs(currentW - targetW) < 30) btn.classList.add('active');
      } else if (cfg.w === DEFAULT_CONFIGS[widgetId].w) {
        btn.classList.add('active');
      }
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (preset.w) {
          widget.style.width = preset.w;
          cfg.w = preset.w;
        } else {
          widget.style.width = DEFAULT_CONFIGS[widgetId].w;
          cfg.w = DEFAULT_CONFIGS[widgetId].w;
        }
        appState.order = getActiveWidgets();
        saveState();
        termLog('Größe: ' + (preset.w || 'Standard'));
        removeSizePicker();
      });
      picker.appendChild(btn);
    });

    document.body.appendChild(picker);

    // Position above widget
    let top = rect.top - picker.offsetHeight - 8;
    if (top < 10) top = rect.bottom + 8;
    let left = rect.left + rect.width / 2 - picker.offsetWidth / 2;
    if (left < 10) left = 10;
    if (left + picker.offsetWidth > window.innerWidth - 10) left = window.innerWidth - picker.offsetWidth - 10;

    picker.style.top = top + 'px';
    picker.style.left = left + 'px';

    sizePickerTimeout = setTimeout(() => removeSizePicker(), 5000);
  }

  function removeSizePicker() {
    const p = document.getElementById('sizePicker');
    if (p) p.remove();
    if (sizePickerTimeout) { clearTimeout(sizePickerTimeout); sizePickerTimeout = null; }
  }

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.size-picker') && !e.target.closest('.widget')) {
      removeSizePicker();
    }
  });

  // ========== v8: DROP PREVIEW (Auto-Umordnen mit Vorschau) ==========
  let dropPreview = null;
  let dropPreviewIndex = -1; // v8: Cache to prevent flicker

  function showDropPreview(idx) {
    if (idx === dropPreviewIndex) return; // No change, skip
    dropPreviewIndex = idx;
    removeDropPreview();
    const dash = document.getElementById('dashboard');
    dash.classList.add('reordering');
    const preview = document.createElement('div');
    preview.className = 'drop-preview';
    preview.id = 'dropPreview';
    const widgets = dash.querySelectorAll('.widget');
    // Apply reorder-shift to widgets that will move
    let shifted = false;
    widgets.forEach((w, i) => {
      if (i >= idx) {
        w.classList.add('reorder-shift');
        shifted = true;
      } else {
        w.classList.remove('reorder-shift');
      }
    });
    if (idx < widgets.length) {
      dash.insertBefore(preview, widgets[idx]);
    } else {
      const ph = document.getElementById('emptyPlaceholder');
      if (ph) dash.insertBefore(preview, ph);
      else dash.appendChild(preview);
    }
  }

  function removeDropPreview() {
    const p = document.getElementById('dropPreview');
    if (p) p.remove();
    const dash = document.getElementById('dashboard');
    dash.classList.remove('reordering');
    // Remove reorder-shift from all widgets
    dash.querySelectorAll('.widget.reorder-shift').forEach(w => w.classList.remove('reorder-shift'));
    dropPreviewIndex = -1;
  }

  function getDropIndex(e) {
    const dash = document.getElementById('dashboard');
    const widgets = Array.from(dash.querySelectorAll('.widget:not(#dropPreview)'));
    if (widgets.length === 0) return 0;
    // v8 Snap: Find nearest widget by vertical midpoint
    let bestIdx = widgets.length;
    let bestDist = Infinity;
    for (let i = 0; i < widgets.length; i++) {
      const rect = widgets[i].getBoundingClientRect();
      const midY = rect.top + rect.height / 2;
      const dist = Math.abs(e.clientY - midY);
      if (dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    }
    // If cursor is below the midpoint of the closest widget, insert after it
    const bestRect = widgets[Math.min(bestIdx, widgets.length - 1)].getBoundingClientRect();
    if (e.clientY > bestRect.top + bestRect.height / 2) {
      bestIdx = Math.min(bestIdx + 1, widgets.length);
    }
    return bestIdx;
  }

  // ========== ADD / REMOVE WIDGET ==========
  function addWidgetToDashboard(widgetId, position = -1, instanceId = null) {
    // Check if this widget supports instances
    const isInstanceWidget = (widgetId === 'terminal' || widgetId === 'chat');
    const actualId = isInstanceWidget && instanceId ? `${widgetId}-${instanceId}` : widgetId;
    
    if (!isInstanceWidget && document.querySelector(`#dashboard .widget[data-widget="${widgetId}"]`)) return;
    if (isInstanceWidget && instanceId && document.querySelector(`#dashboard .widget[data-instance="${actualId}"]`)) return;
    
    const def = WIDGET_DEFS[widgetId];
    if (!def) return;
    const cfg = getWidgetConfig(widgetId);
    const name = isInstanceWidget && instanceId ? `${def.name} (${instanceId})` : def.name;

    const widget = document.createElement('div');
    widget.className = 'widget';
    widget.dataset.widget = widgetId;
    if (isInstanceWidget && instanceId) widget.dataset.instance = actualId;
    widget.draggable = !appState.locked;
    widget.style.width = cfg.w;
    if (cfg.h !== 'auto') widget.style.height = cfg.h;

    widget.innerHTML = `
      <div class="widget-header">
        <span class="w-icon">${def.icon}</span>
        <span class="w-name">${name}</span>
        <button class="w-lock" title="Widget sperren" onclick="toggleWidgetLock(event, '${actualId}')">🔓</button>
        <button class="w-fs-btn" title="Schrift kleiner" onclick="changeFont(event, '${actualId}', -1)">A⁻</button>
        <button class="w-fs-btn" title="Schrift größer" onclick="changeFont(event, '${actualId}', 1)">A⁺</button>
        <button class="w-remove" title="Widget entfernen" onclick="removeWidget(event, '${actualId}')">×</button>
      </div>
      <div class="widget-body"></div>
      <div class="resize-handle" title="Größe anpassen"></div>
    `;

    widget.addEventListener('dragstart', onWidgetDragStart);
    widget.addEventListener('dragend', onWidgetDragEnd);

    // v8: Click on widget header shows size picker
    widget.querySelector('.widget-header').addEventListener('dblclick', (e) => {
      if (appState.locked || widget.classList.contains('widget-locked')) return;
      showSizePicker(widget, widgetId);
    });

    const handle = widget.querySelector('.resize-handle');
    handle.addEventListener('mousedown', (e) => startResize(e, widget, widgetId));

    const dashboard = document.getElementById('dashboard');
    const placeholder = document.getElementById('emptyPlaceholder');

    if (position >= 0) {
      const widgets = dashboard.querySelectorAll('.widget');
      if (position < widgets.length) {
        dashboard.insertBefore(widget, widgets[position]);
      } else {
        if (placeholder) dashboard.insertBefore(widget, placeholder);
        else dashboard.appendChild(widget);
      }
    } else {
      if (placeholder) dashboard.insertBefore(widget, placeholder);
      else dashboard.appendChild(widget);
    }

    if (placeholder) placeholder.style.display = 'none';

    const body = widget.querySelector('.widget-body');
    def.render(body, cfg.fs);

    applyWidgetLockState(widgetId);

    if (widgetId === 'terminal') ptyInit();

    appState.order = getActiveWidgets();
    saveState();
    updateSidebar();
    termLog('Widget ' + def.name + ' hinzugefügt');

    // Show size picker briefly for new widgets
    setTimeout(() => {
      if (!appState.locked && !widget.classList.contains('widget-locked')) showSizePicker(widget, widgetId);
    }, 400);
  }

  function removeWidget(event, widgetId) {
    if (appState.locked || isWidgetLocked(widgetId)) return;
    event.stopPropagation();
    if (widgetId === 'terminal') ptyDispose();
    const widget = document.querySelector(`#dashboard .widget[data-widget="${widgetId}"]`);
    if (widget) {
      const name = WIDGET_DEFS[widgetId]?.name || widgetId;
      widget.style.transition = 'opacity 0.15s, transform 0.15s';
      widget.style.opacity = '0';
      widget.style.transform = 'scale(0.95)';
      removeSizePicker();
      setTimeout(() => {
        widget.remove();
        const db = document.getElementById('dashboard');
        if (!db.querySelector('.widget')) {
          const ph = document.getElementById('emptyPlaceholder');
          if (ph) ph.style.display = '';
        }
        appState.order = getActiveWidgets();
        saveState();
        updateSidebar();
        termLog('Widget ' + name + ' entfernt');
      }, 150);
    }
  }

  function updateSidebar() {
    const active = getActiveWidgets();
    document.querySelectorAll('.lib-widget').forEach(lib => {
      const wid = lib.dataset.widget;
      if (active.includes(wid)) {
        lib.classList.add('placed');
        lib.draggable = false;
      } else {
        lib.classList.remove('placed');
        lib.draggable = !appState.locked;
      }
    });
  }

  // ========== RESIZE ==========
  let resizeState = null;

  function startResize(e, widget, widgetId) {
    if (appState.locked || widget.classList.contains('widget-locked')) return;
    e.preventDefault();
    e.stopPropagation();
    const rect = widget.getBoundingClientRect();
    resizeState = { widget, widgetId, startX: e.clientX, startY: e.clientY, startW: rect.width, startH: rect.height };
    widget.classList.add('resizing');
    document.addEventListener('mousemove', onResizeMove);
    document.addEventListener('mouseup', onResizeEnd);
  }

  function onResizeMove(e) {
    if (!resizeState) return;
    const { widget, startX, startY, startW, startH } = resizeState;
    let newW = startW + (e.clientX - startX);
    let newH = startH + (e.clientY - startY);
    newW = Math.round(newW / SNAP) * SNAP;
    newH = Math.round(newH / SNAP) * SNAP;
    newW = Math.max(180, newW);
    newH = Math.max(100, newH);
    widget.style.width = newW + 'px';
    widget.style.height = newH + 'px';
  }

  function onResizeEnd(e) {
    if (!resizeState) return;
    const { widget, widgetId } = resizeState;
    widget.classList.remove('resizing');
    resizeState = null;
    document.removeEventListener('mousemove', onResizeMove);
    document.removeEventListener('mouseup', onResizeEnd);
    const cfg = getWidgetConfig(widgetId);
    cfg.w = widget.style.width;
    cfg.h = widget.style.height;
    appState.order = getActiveWidgets();
    saveState();
  }

  // ========== DRAG & DROP ==========
  let draggedWidgetId = null;
  let draggedFromSidebar = false;
  let instanceCounters = { terminal: 1, chat: 1 };

  // Instance buttons in sidebar
  document.querySelectorAll('.lib-instance[data-action="add-instance"]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (appState.locked) return;
      const wid = btn.dataset.widget;
      instanceCounters[wid] = (instanceCounters[wid] || 0) + 1;
      const instanceId = instanceCounters[wid];
      addWidgetToDashboard(wid, -1, instanceId);
      appState.order = getActiveWidgets();
      saveState();
    });
  });
  let dragSourceElement = null;

  document.querySelectorAll('.lib-widget').forEach(lib => {
    lib.addEventListener('dragstart', e => {
      if (appState.locked || lib.classList.contains('placed')) { e.preventDefault(); return; }
      draggedWidgetId = lib.dataset.widget;
      draggedFromSidebar = true;
      dragSourceElement = lib;
      lib.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'copy';
    });
    lib.addEventListener('dragend', e => {
      lib.classList.remove('dragging');
      draggedWidgetId = null;
      draggedFromSidebar = false;
      dragSourceElement = null;
      removeDropPreview();
    });
  });

  function onWidgetDragStart(e) {
    if (appState.locked || this.classList.contains('widget-locked')) { e.preventDefault(); return; }
    if (e.target.closest('.w-remove, .w-fs-btn, .resize-handle, .w-lock')) { e.preventDefault(); return; }
    removeSizePicker();
    draggedWidgetId = this.dataset.widget;
    draggedFromSidebar = false;
    dragSourceElement = this;
    this.classList.add('drag-ghost');
    e.dataTransfer.effectAllowed = 'move';
  }

  function onWidgetDragEnd(e) {
    this.classList.remove('drag-ghost');
    draggedWidgetId = null;
    draggedFromSidebar = false;
    dragSourceElement = null;
    removeDropPreview();
  }

  const dashboard = document.getElementById('dashboard');

  dashboard.addEventListener('dragover', e => {
    if (appState.locked) return;
    e.preventDefault();
    e.dataTransfer.dropEffect = draggedFromSidebar ? 'copy' : 'move';
    dashboard.classList.add('drag-over');

    // v8: Show drop preview (auto-reorder)
    const insertIdx = getDropIndex(e);
    showDropPreview(insertIdx);
  });

  dashboard.addEventListener('dragleave', e => {
    if (!dashboard.contains(e.relatedTarget)) {
      dashboard.classList.remove('drag-over');
      removeDropPreview();
    }
  });

  dashboard.addEventListener('drop', e => {
    e.preventDefault();
    dashboard.classList.remove('drag-over');
    removeDropPreview();
    if (appState.locked || !draggedWidgetId) return;

    const insertIdx = getDropIndex(e);

    if (!draggedFromSidebar && dragSourceElement) {
      const widgets = Array.from(dashboard.querySelectorAll('.widget'));
      const srcIdx = widgets.indexOf(dragSourceElement);
      if (srcIdx >= 0 && srcIdx < insertIdx) {
        // Adjust because we're removing the source
        dragSourceElement.remove();
        addWidgetToDashboard(draggedWidgetId, insertIdx - 1);
      } else {
        dragSourceElement.remove();
        addWidgetToDashboard(draggedWidgetId, insertIdx);
      }
    } else {
      addWidgetToDashboard(draggedWidgetId, insertIdx);
    }

    draggedWidgetId = null;
    draggedFromSidebar = false;
    if (dragSourceElement && !draggedFromSidebar) dragSourceElement.classList.remove('drag-ghost');
    dragSourceElement = null;
  });

  // ========== PTY TERMINAL ==========
  const PTY_WS_URL = 'ws://127.0.0.1:8000/ws/pty';
  const PTY_RECONNECT_MS = 3000;
  let ptyWs = null;
  let ptyReconnectTimer = null;
  let ptyTerm = null;
  let ptyFitAddon = null;
  let ptyResizeObserver = null;

  function ptyInit() {
    const container = document.getElementById('ptyContainer');
    if (!container || ptyTerm) return;

    ptyTerm = new Terminal({
      cursorBlink: true,
      cursorStyle: 'bar',
      fontSize: 13,
      fontFamily: '"JetBrains Mono", "Fira Code", "SF Mono", monospace',
      theme: {
        background: '#0d1117',
        foreground: '#e1e5f2',
        cursor: '#7fb3ff',
        selectionBackground: '#1e3a5f',
      },
      allowProposedApi: true,
    });

    ptyFitAddon = new FitAddon.FitAddon();
    ptyTerm.loadAddon(ptyFitAddon);
    ptyTerm.loadAddon(new WebLinksAddon.WebLinksAddon());

    ptyTerm.open(container);
    ptyFitAddon.fit();

    window._ptyTerm = ptyTerm;

    ptyTerm.onData(function(data) {
      if (ptyWs && ptyWs.readyState === WebSocket.OPEN) {
        var bytes = new TextEncoder().encode(data);
        var binary = '';
        for (var i = 0; i < bytes.length; i++) {
          binary += String.fromCharCode(bytes[i]);
        }
        ptyWs.send(JSON.stringify({ type: 'input', data: btoa(binary) }));
      }
    });

    ptyWsConnect();

    const widget = container.closest('.widget');
    if (widget) {
      ptyResizeObserver = new ResizeObserver(function() {
        if (ptyFitAddon && ptyTerm) {
          ptyFitAddon.fit();
          var dims = ptyFitAddon.proposeDimensions();
          if (dims && ptyWs && ptyWs.readyState === WebSocket.OPEN) {
            ptyWs.send(JSON.stringify({ type: 'resize', rows: dims.rows, cols: dims.cols }));
          }
        }
      });
      ptyResizeObserver.observe(widget);
    }
  }

  function ptyDispose() {
    if (ptyResizeObserver) { ptyResizeObserver.disconnect(); ptyResizeObserver = null; }
    if (ptyWs) { ptyWs.close(); ptyWs = null; }
    if (ptyReconnectTimer) { clearTimeout(ptyReconnectTimer); ptyReconnectTimer = null; }
    if (ptyTerm) { ptyTerm.dispose(); ptyTerm = null; ptyFitAddon = null; }
    window._ptyTerm = undefined;
  }

  function ptyWsConnect() {
    if (ptyWs && (ptyWs.readyState === WebSocket.OPEN || ptyWs.readyState === WebSocket.CONNECTING)) return;

    ptyWs = new WebSocket(PTY_WS_URL);
    var footer = document.getElementById('termStatusFooter');
    if (footer) footer.innerHTML = '<span class="term-status-dot term-status-dot--connecting"></span><span>verbinde...</span>';

    ptyWs.onopen = function() {
      if (footer) footer.innerHTML = '<span class="term-status-dot term-status-dot--connected"></span><span>verbunden</span>';
      function sendResize() {
        if (ptyFitAddon && ptyTerm && ptyWs && ptyWs.readyState === WebSocket.OPEN) {
          ptyFitAddon.fit();
          var dims = ptyFitAddon.proposeDimensions();
          if (dims) {
            ptyWs.send(JSON.stringify({ type: 'resize', rows: dims.rows, cols: dims.cols }));
          }
        }
      }
      sendResize();
      setTimeout(sendResize, 150);
      setTimeout(sendResize, 400);
    };

    ptyWs.onmessage = function(raw) {
      try {
        var msg = JSON.parse(raw.data);
        if (msg.type === 'output' && ptyTerm) {
          var binary = atob(msg.data);
          var out = new Uint8Array(binary.length);
          for (var i = 0; i < binary.length; i++) {
            out[i] = binary.charCodeAt(i);
          }
          ptyTerm.write(out);
        } else if (msg.type === 'exit') {
          if (ptyTerm) ptyTerm.writeln('\r\n\x1b[33m[Prozess beendet, Code: ' + msg.code + ']\x1b[0m');
        }
      } catch (_) {}
    };

    ptyWs.onclose = function() {
      ptyWs = null;
      if (footer) footer.innerHTML = '<span class="term-status-dot term-status-dot--disconnected"></span><span>getrennt</span>';
      if (ptyReconnectTimer) clearTimeout(ptyReconnectTimer);
      ptyReconnectTimer = setTimeout(ptyWsConnect, PTY_RECONNECT_MS);
    };

    ptyWs.onerror = function() {};
  }

  // ========== v8: LIVE DATA ==========
  const API_BASE = 'http://127.0.0.1:8000';
  let pageStartTime = performance.now();

  function updateLiveClock() {
    const now = new Date();
    const dateEl = document.getElementById('sidebarDate');
    if (dateEl) {
      dateEl.textContent = now.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }
    const uptimeEl = document.getElementById('sysUptimeVal');
    if (uptimeEl) {
      const mins = Math.floor((performance.now() - pageStartTime) / 60000);
      const hrs = Math.floor(mins / 60);
      uptimeEl.textContent = hrs + 'h ' + (mins % 60) + 'm (seit Seitenaufruf)';
    }
  }

  // ── System ──
  async function fetchSystem() {
    try {
      const resp = await fetch(API_BASE + '/api/system');
      if (!resp.ok) return;
      const d = await resp.json();
      const cpuEl = document.getElementById('sysCpuVal');
      const cpuBar = document.getElementById('sysCpuBar');
      if (cpuEl) cpuEl.textContent = d.cpu_percent + '%';
      if (cpuBar) cpuBar.style.width = d.cpu_percent + '%';

      const ramEl = document.getElementById('sysRamVal');
      const ramBar = document.getElementById('sysRamBar');
      if (ramEl) ramEl.textContent = d.ram_used_gb + ' / ' + d.ram_total_gb + ' GB (' + d.ram_percent + '%)';
      if (ramBar) ramBar.style.width = d.ram_percent + '%';

      const diskEl = document.getElementById('sysDiskVal');
      const diskBar = document.getElementById('sysDiskBar');
      if (diskEl) diskEl.textContent = d.disk_used_gb + ' / ' + d.disk_total_gb + ' GB (' + d.disk_percent + '%)';
      if (diskBar) diskBar.style.width = d.disk_percent + '%';

      const netEl = document.getElementById('sysNetVal');
      if (netEl) netEl.textContent = d.network_kb_s + ' KB/s';
    } catch (err) {
      console.warn('System fetch failed:', err);
    }
  }

  // ── Weather ──
  async function fetchWeather() {
    try {
      const resp = await fetch(API_BASE + '/api/weather');
      if (!resp.ok) throw new Error('HTTP ' + resp.status);
      const data = await resp.json();
      if (data.error) throw new Error(data.error);
      const current = data.current_condition[0];
      const wxIcon = document.getElementById('wxIcon');
      const wxTemp = document.getElementById('wxTemp');
      const wxDesc = document.getElementById('wxDesc');
      const wxStats = document.getElementById('wxStats');
      const wxForecast = document.getElementById('wxForecast');

      if (wxTemp) wxTemp.textContent = current.temp_C + '\u00b0';
      if (wxDesc) wxDesc.textContent = current.weatherDesc[0].value;
      if (wxIcon) {
        const code = current.weatherCode;
        const icons = { 113: '\u2600', 116: '\u26c5', 119: '\u2601', 122: '\u2601', 143: '\ud83c\udf2b', 176: '\ud83c\udf26', 179: '\ud83c\udf28', 182: '\ud83c\udf28', 185: '\ud83c\udf28', 200: '\u26c8', 227: '\ud83c\udf2c', 230: '\ud83c\udf2c', 248: '\ud83c\udf2b', 260: '\ud83c\udf2b', 263: '\ud83c\udf27', 266: '\ud83c\udf27', 281: '\ud83c\udf27', 284: '\ud83c\udf27', 293: '\ud83c\udf27', 296: '\ud83c\udf27', 299: '\ud83c\udf27', 302: '\ud83c\udf27', 305: '\ud83c\udf27', 308: '\ud83c\udf27', 311: '\ud83c\udf27', 314: '\ud83c\udf27', 317: '\ud83c\udf27', 320: '\ud83c\udf28', 323: '\ud83c\udf28', 326: '\ud83c\udf28', 329: '\ud83c\udf28', 332: '\ud83c\udf28', 335: '\ud83c\udf28', 338: '\ud83c\udf28', 350: '\ud83c\udf28', 353: '\ud83c\udf27', 356: '\ud83c\udf27', 359: '\ud83c\udf27', 362: '\ud83c\udf28', 365: '\ud83c\udf28', 368: '\ud83c\udf28', 371: '\ud83c\udf28', 374: '\ud83c\udf28', 377: '\ud83c\udf28', 386: '\u26c8', 389: '\u26c8', 392: '\u26c8', 395: '\ud83c\udf28' };
        wxIcon.textContent = icons[code] || '\ud83c\udf24';
      }
      if (wxStats) wxStats.innerHTML = '<span>\ud83d\udca7 ' + current.humidity + '%</span><span>\ud83c\udf2c ' + current.windspeedKmph + ' km/h</span><span>\ud83d\udc41 ' + current.visibility + ' km</span>';
      if (wxForecast && data.weather) {
        const t = data.weather;
        wxForecast.textContent = 'Morgen: ' + (t[1] ? t[1].mintempC + '\u2013' + t[1].maxtempC + '\u00b0' : '?') + ' \u00b7 Uebermorgen: ' + (t[2] ? t[2].mintempC + '\u2013' + t[2].maxtempC + '\u00b0' : '?');
      }
    } catch (err) {
      const wxDesc = document.getElementById('wxDesc');
      const wxTemp = document.getElementById('wxTemp');
      if (wxDesc) wxDesc.textContent = 'API offline';
      if (wxTemp) wxTemp.textContent = '--';
    }
  }

  // ── Jobs ──
  async function fetchJobs() {
    try {
      const resp = await fetch(API_BASE + '/api/cron');
      if (!resp.ok) return;
      const data = await resp.json();
      const container = document.getElementById('jobsContainer');
      if (!container) return;
      if (!data.jobs || data.jobs.length === 0) {
        container.innerHTML = '<span class="term-dim">Keine Cron-Jobs gefunden</span>';
        return;
      }
      container.innerHTML = data.jobs.map(j => {
        const name = j.name || j.id || '?';
        const sched = j.schedule || '';
        const lastRun = j.last_run || '';
        const statusClass = (lastRun.includes('ok') || j.status === 'active') ? 'ok' : '';
        const statusText = j.status || (lastRun.includes('ok') ? 'ok' : '--');
        return '<div class="job-row"><div><div class="job-title">' + name + '</div><div class="job-sched">' + sched + '</div></div><span class="job-stat ' + statusClass + '">' + statusText + '</span></div>';
      }).join('');
    } catch (err) {
      console.warn('Jobs fetch failed:', err);
    }
  }

  // ── News ──
  async function fetchNews() {
    try {
      const resp = await fetch(API_BASE + '/api/news');
      if (!resp.ok) return;
      const data = await resp.json();
      const container = document.getElementById('newsContainer');
      if (!container) return;
      if (!data.news || data.news.length === 0) {
        container.innerHTML = '<span class="term-dim">Keine News geladen</span>';
        return;
      }
      container.innerHTML = data.news.map(n =>
        '<div class="news-item"><div class="n-title">' + (n.title || '') + '</div><div class="n-source">' + (n.source || '') + (n.time ? ' \u00b7 ' + n.time : '') + '</div></div>'
      ).join('') + '<div class="news-more">Mehr News laden \u2192</div>';
    } catch (err) {
      console.warn('News fetch failed:', err);
    }
  }

  // ── Agents ──
  async function fetchAgents() {
    try {
      const resp = await fetch(API_BASE + '/api/agents');
      if (!resp.ok) return;
      const data = await resp.json();
      const container = document.getElementById('agentsContainer');
      if (!container) return;
      if (!data.agents || data.agents.length === 0) {
        container.innerHTML = '<span class="term-dim">Keine Agenten gefunden</span>';
        return;
      }
      container.innerHTML = data.agents.map(a => {
        const isLive = a.reifegrad !== 'local';
        const dotClass = isLive ? 'on' : 'idle';
        return '<div class="agent-card">'
          + '<div class="agent-avatar' + (isLive ? ' hermes' : '') + '">' + (a.name || '?')[0].toUpperCase() + '</div>'
          + '<div class="agent-info"><div class="agent-name">' + a.name + '</div><div class="agent-stat">Runs: ' + a.runs + (a.errors ? ' \u00b7 Fehler: ' + a.errors : '') + '</div></div>'
          + '<div class="agent-status-dot ' + dotClass + '"></div>'
          + '</div>';
      }).join('');
    } catch (err) {
      console.warn('Agents fetch failed:', err);
    }
  }

  // ── Tasks ──
  async function fetchTasks() {
    try {
      const resp = await fetch(API_BASE + '/api/tasks');
      if (!resp.ok) return;
      const data = await resp.json();
      const pendingCol = document.getElementById('taskColPending');
      const doneCol = document.getElementById('taskColDone');
      if (!pendingCol && !doneCol) return;

      const tasks = data.tasks || [];
      const pending = tasks.filter(t => t.status !== 'done' && t.status !== 'erledigt');
      const done = tasks.filter(t => t.status === 'done' || t.status === 'erledigt');

      if (pendingCol) {
        const cntEl = pendingCol.querySelector('.cnt');
        if (cntEl) cntEl.textContent = pending.length;
        const existing = pendingCol.querySelectorAll('.task-card');
        existing.forEach(el => el.remove());
        const addEl = pendingCol.querySelector('.task-add');
        pending.forEach(t => {
          const card = document.createElement('div');
          card.className = 'task-card pending-card';
          card.innerHTML = '<div class="task-card-header"><div class="task-check-circle">\u2713</div><div class="task-title">' + (t.title || '') + '</div></div>'
            + '<div class="task-meta">' + (t.priority ? '<span class="priority ' + t.priority.toLowerCase() + '">' + t.priority.toUpperCase() + '</span>' : '') + (t.agent ? '<span>' + t.agent + '</span>' : '') + (t.due ? '<span>' + t.due + '</span>' : '') + '</div>';
          card.addEventListener('click', () => completeTask(card));
          if (addEl) pendingCol.insertBefore(card, addEl);
        });
        if (!pendingCol.querySelector('.task-add')) {
          const newAdd = document.createElement('div');
          newAdd.className = 'task-add';
          newAdd.textContent = '+ Neue Task';
          newAdd.addEventListener('click', (e) => addNewTask(e.currentTarget.closest('.widget-body')));
          pendingCol.appendChild(newAdd);
        }
      }

      if (doneCol) {
        const cntEl = doneCol.querySelector('.cnt');
        if (cntEl) cntEl.textContent = done.length;
        const existing = doneCol.querySelectorAll('.task-card');
        existing.forEach(el => el.remove());
        done.forEach(t => {
          const card = document.createElement('div');
          card.className = 'task-card completed-card';
          card.innerHTML = '<div class="task-card-header"><div class="task-check-circle">\u2713</div><div class="task-title">' + (t.title || '') + '</div></div>'
            + '<div class="task-meta">' + (t.agent ? '<span>' + t.agent + '</span>' : '') + (t.due ? '<span>' + t.due + '</span>' : '') + '</div>';
          card.addEventListener('click', () => uncompleteTask(card));
          doneCol.appendChild(card);
        });
      }
    } catch (err) {
      console.warn('Tasks fetch failed:', err);
    }
  }

  // ── Skills ──
  async function fetchSkills() {
    try {
      const resp = await fetch(API_BASE + '/api/skills');
      if (!resp.ok) return;
      const data = await resp.json();
      const container = document.getElementById('skillsContainer');
      if (!container) return;
      if (!data.skills || data.skills.length === 0) {
        container.innerHTML = '<span class="term-dim">Keine Skills gefunden</span>';
        return;
      }
      container.innerHTML = data.skills.map(s =>
          '<span class="skill-tag">' + s + '</span>'
      ).join('');

    // Update sidebar skills counter
    const skillsVal = document.getElementById('sidebarSkillsVal');
    if (skillsVal) skillsVal.textContent = (data.skills || []).length + ' verfuegbar';
    } catch (err) {
      console.warn('Skills fetch failed:', err);
    }
  }

  // ── Memory ──
  async function fetchMemory() {
    try {
      const resp = await fetch(API_BASE + '/api/memory');
      if (!resp.ok) return;
      const data = await resp.json();
      const content = data.content || '';
      const chars = content.length;
      const maxChars = 8000;
      const percent = Math.min(100, Math.round(chars / maxChars * 100));
      const memVal = document.getElementById('sidebarMemoryVal');
      const memBar = document.getElementById('sidebarMemoryBar');
      if (memVal) memVal.textContent = chars.toLocaleString() + ' / ' + maxChars.toLocaleString();
      if (memBar) {
        memBar.style.width = percent + '%';
        memBar.className = 'mini-bar-fill ' + (percent > 75 ? 'orange' : 'blue');
      }
    } catch (err) {
      console.warn('Memory fetch failed:', err);
    }
  }

  // ========== SIDEBAR RESIZE ==========
  function initSidebarResize() {
    const sidebar = document.getElementById('sidebar');
    const handle = document.getElementById('sidebarResizeHandle');
    if (!sidebar || !handle) return;

    let startX, startWidth;

    handle.addEventListener('mousedown', (e) => {
      e.preventDefault();
      startX = e.clientX;
      startWidth = sidebar.offsetWidth;
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';

      function onMouseMove(e) {
        const delta = e.clientX - startX;
        const newWidth = Math.max(220, Math.min(400, startWidth + delta));
        sidebar.style.width = newWidth + 'px';
        document.documentElement.style.setProperty('--sidebar-width', newWidth + 'px');
      }

      function onMouseUp() {
        document.body.style.cursor = '';
        document.body.style.userSelect = '';
        document.removeEventListener('mousemove', onMouseMove);
        document.removeEventListener('mouseup', onMouseUp);
      }

      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
    });
  }

  // ========== KEYBOARD SHORTCUT ==========
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'l') {
      e.preventDefault();
      toggleLock();
    }
  });

  // ========== RESET ==========
  function resetAllLayout() {
    if (!confirm('Gesamtes Layout zuruecksetzen? Alle Widgets und Groessen gehen verloren.')) return;
    localStorage.removeItem(STORAGE_KEY);
    location.reload();
  }

  // ========== INIT ==========
  function init() {
    pageStartTime = performance.now();
    applyLockState();

    const { order } = appState;
    order.forEach(wid => addWidgetToDashboard(wid));
    applyAllWidgetLockStates();
    updateSidebar();

    initSidebarResize();

    updateLiveClock();
    setInterval(updateLiveClock, 30000);

    fetchSystem();
    setInterval(fetchSystem, 2000);

    fetchWeather();
    setInterval(fetchWeather, 30000);

    fetchJobs();
    setInterval(fetchJobs, 30000);

    fetchNews();
    setInterval(fetchNews, 30000);

    fetchAgents();
    setInterval(fetchAgents, 30000);

    fetchTasks();
    setInterval(fetchTasks, 30000);

    fetchSkills();
    setInterval(fetchSkills, 30000);

    fetchMemory();
    setInterval(fetchMemory, 30000);

    ptyInit();
  }

  window.addEventListener('DOMContentLoaded', init);
</script>
